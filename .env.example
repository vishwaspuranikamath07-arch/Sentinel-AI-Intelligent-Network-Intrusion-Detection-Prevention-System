# =============================================================================
# AI-NIDS — Environment Variables Template
# =============================================================================
#
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. NEVER commit your .env file to version control
#   4. Add .env to your .gitignore (already done in this project)
#
# All variables are prefixed with AINIDS_ as configured in settings.py
# =============================================================================

# ---------------------------------------------------------------------------
# Application Identity
# ---------------------------------------------------------------------------
AINIDS_APP_NAME="AI-NIDS"
AINIDS_APP_VERSION="1.0.0"
AINIDS_DEBUG=false
AINIDS_ENVIRONMENT="development"       # development | staging | production

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
AINIDS_HOST="0.0.0.0"
AINIDS_PORT=8000
AINIDS_WORKERS=1
AINIDS_RELOAD=false

# ---------------------------------------------------------------------------
# Security — CRITICAL: Change these in production!
# ---------------------------------------------------------------------------
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
AINIDS_SECRET_KEY="REPLACE_WITH_A_STRONG_RANDOM_SECRET_KEY"
AINIDS_ALGORITHM="HS256"
AINIDS_ACCESS_TOKEN_EXPIRE_MINUTES=30
AINIDS_REFRESH_TOKEN_EXPIRE_DAYS=7

AINIDS_ADMIN_USERNAME="admin"
AINIDS_ADMIN_PASSWORD="REPLACE_WITH_A_STRONG_PASSWORD"

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite (default — good for development and small deployments)
AINIDS_DATABASE_URL="sqlite:///./data/nids.db"
AINIDS_DATABASE_ECHO=false

# PostgreSQL example (for production):
# AINIDS_DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/nids_db"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
AINIDS_LOG_LEVEL="INFO"               # DEBUG | INFO | WARNING | ERROR | CRITICAL
AINIDS_LOG_MAX_BYTES=10485760         # 10 MB
AINIDS_LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# Packet Capture
# ---------------------------------------------------------------------------
# Leave empty to auto-detect the default interface
AINIDS_CAPTURE_INTERFACE=""
AINIDS_CAPTURE_FILTER=""              # BPF filter, e.g. "tcp port 80"
AINIDS_CAPTURE_TIMEOUT=0             # 0 = infinite
AINIDS_CAPTURE_PACKET_COUNT=0        # 0 = unlimited
AINIDS_CAPTURE_BUFFER_SIZE=1000
AINIDS_CAPTURE_ENABLED=false         # Set to true to start capture on launch

# ---------------------------------------------------------------------------
# Machine Learning
# ---------------------------------------------------------------------------
AINIDS_TEST_SIZE=0.2
AINIDS_RANDOM_STATE=42
AINIDS_CV_FOLDS=5
AINIDS_N_JOBS=-1                     # -1 = use all CPU cores
AINIDS_PREDICTION_THRESHOLD=0.5

# ---------------------------------------------------------------------------
# Alert Thresholds
# ---------------------------------------------------------------------------
AINIDS_ALERT_RETENTION_DAYS=30
AINIDS_HIGH_THREAT_THRESHOLD=0.9
AINIDS_MEDIUM_THREAT_THRESHOLD=0.7

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
AINIDS_CORS_ORIGINS='["http://localhost:3000","http://localhost:8000"]'
