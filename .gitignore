# =============================================================================
# AI-NIDS — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Secrets & Environment
# ---------------------------------------------------------------------------
.env
.env.local
.env.production
*.key
*.pem
*.cert

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.whl

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
*.coveragerc
coverage.xml
.mypy_cache/

# ---------------------------------------------------------------------------
# IDE & Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db

# ---------------------------------------------------------------------------
# Project-Specific
# ---------------------------------------------------------------------------
logs/*.log
logs/*.log.*
data/raw/*.csv
data/raw/*.txt
data/raw/*.arff
data/processed/
saved_models/*.pkl
saved_models/*.joblib
saved_models/*.model
data/nids.db
data/*.db

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
.dockerignore

# ---------------------------------------------------------------------------
# Notebooks
# ---------------------------------------------------------------------------
notebooks/.ipynb_checkpoints/

# ---------------------------------------------------------------------------
# Docs Build Output
# ---------------------------------------------------------------------------
site/
docs/build/
